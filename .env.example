# Variables de entorno de ejemplo
# Copiar este archivo como .env.development para desarrollo local

# Configuración general
NODE_ENV=development
PORT=4000

# Base de datos de Products Service
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=products_db

# Base de datos de Orders Service
ORDERS_DB_HOST=localhost
ORDERS_DB_PORT=5433
ORDERS_DB_USERNAME=postgres
ORDERS_DB_PASSWORD=password
ORDERS_DB_NAME=orders_db

# URLs de microservicios (para comunicación entre servicios)
PRODUCTS_SERVICE_URL=http://localhost:4001
ORDERS_SERVICE_URL=http://localhost:4002

# Configuración de JWT (bonus)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Configuración de CORS
CORS_ORIGIN=http://localhost:3000

# Configuración de logging
LOG_LEVEL=debug

# Configuración de Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Configuración de timeouts
HTTP_TIMEOUT=10000

# Configuración de Swagger
SWAGGER_ENABLED=true
