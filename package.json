{
  "name": "linktic-ecommerce",
  "version": "1.0.0",
  "description": "Plataforma E-commerce con microservicios - Prueba Técnica Linktic",
  "main": "index.js",
  "scripts": {
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint",
    "build:products": "cd apps/products-service && nest build",
    "build:orders": "cd apps/orders-service && nest build",
    "build:gateway": "cd apps/api-gateway && nest build",
    "build:all": "npm run build:shared && npm run build:products && npm run build:orders && npm run build:gateway",
    "start:all": "docker-compose up -d postgres-products postgres-orders && powershell -ExecutionPolicy Bypass -File start-all.ps1",
    "stop:all": "docker-compose down && taskkill /F /IM node.exe 2>nul || true",
    "serve:api-gateway": "cd apps/api-gateway && nest start --watch",
    "serve:products-service": "cd apps/products-service && nest start --watch",
    "serve:orders-service": "cd apps/orders-service && nest start --watch",
    "serve:frontend": "cd apps/frontend && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build:shared": "nx build shared",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "migrate:products": "nx run products-service:migrate",
    "migrate:orders": "nx run orders-service:migrate"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.2",
    "@nx/js": "^19.1.0",
    "@nx/nest": "^19.1.0",
    "@nx/node": "^19.1.0",
    "@nx/react": "^19.1.0",
    "@nx/workspace": "^19.1.0",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "nx": "^19.1.0",
    "prettier": "^3.2.5",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.1",
    "@nestjs/common": "^10.3.2",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.2",
    "@nestjs/platform-express": "^10.3.2",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/typeorm": "^10.0.1",
    "axios": "^1.6.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  }
}
