{
  "nodes": {
    "products-service": {
      "name": "products-service",
      "type": "app",
      "data": {
        "root": ".",
        "sourceRoot": "src",
        "name": "products-service",
        "tags": [
          "npm:public"
        ],
        "metadata": {
          "targetGroups": {
            "NPM Scripts": [
              "start",
              "migrate:generate"
            ]
          },
          "description": "Microservicio de productos - Gestión de catálogo"
        },
        "targets": {
          "start": {
            "executor": "nx:run-script",
            "options": {
              "script": "start"
            },
            "metadata": {
              "scriptContent": "node dist/main.js",
              "runCommand": "npm run start"
            },
            "configurations": {},
            "parallelism": true
          },
          "migrate:generate": {
            "executor": "nx:run-script",
            "options": {
              "script": "migrate:generate"
            },
            "metadata": {
              "scriptContent": "nx run products-service:migrate-generate",
              "runCommand": "npm run migrate:generate"
            },
            "configurations": {},
            "parallelism": true
          },
          "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "dependsOn": [
              "^nx-release-publish"
            ],
            "options": {},
            "configurations": {},
            "parallelism": true
          },
          "build": {
            "executor": "@nx/nest:build",
            "outputs": [
              "{options.outputPath}"
            ],
            "options": {
              "outputPath": "dist/apps/products-service",
              "main": "src/main.ts",
              "tsConfig": "tsconfig.app.json",
              "assets": [
                "src/assets"
              ]
            },
            "configurations": {
              "production": {
                "optimization": true,
                "extractLicenses": true,
                "inspect": false,
                "fileReplacements": [
                  {
                    "replace": "src/environments/environment.ts",
                    "with": "src/environments/environment.prod.ts"
                  }
                ]
              }
            },
            "parallelism": true
          },
          "serve": {
            "executor": "@nx/nest:serve",
            "options": {
              "buildTarget": "products-service:build"
            },
            "configurations": {
              "production": {
                "buildTarget": "products-service:build:production"
              }
            },
            "parallelism": true
          },
          "lint": {
            "executor": "@nx/linter:eslint",
            "outputs": [
              "{options.outputFile}"
            ],
            "options": {
              "lintFilePatterns": [
                "src/**/*.ts"
              ]
            },
            "configurations": {},
            "parallelism": true
          },
          "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
              "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
              "jestConfig": "jest.config.ts",
              "passWithNoTests": true
            },
            "configurations": {
              "ci": {
                "ci": true,
                "coverageReporters": [
                  "text"
                ]
              }
            },
            "parallelism": true
          },
          "migrate": {
            "executor": "@nx/workspace:run-commands",
            "options": {
              "command": "npx typeorm migration:run",
              "cwd": "."
            },
            "configurations": {},
            "parallelism": true
          },
          "migrate-generate": {
            "executor": "@nx/workspace:run-commands",
            "options": {
              "command": "npx typeorm migration:generate",
              "cwd": "."
            },
            "configurations": {},
            "parallelism": true
          },
          "seed": {
            "executor": "@nx/workspace:run-commands",
            "options": {
              "command": "npx ts-node src/typeorm/seeds/seed.ts",
              "cwd": "."
            },
            "configurations": {},
            "parallelism": true
          }
        },
        "$schema": "../../node_modules/nx/schemas/project-schema.json",
        "projectType": "application",
        "implicitDependencies": []
      }
    }
  },
  "externalNodes": {},
  "dependencies": {
    "products-service": []
  },
  "version": "6.0"
}