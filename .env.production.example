# Variables de entorno para producción
# Usar valores seguros y específicos del entorno

# Configuración general
NODE_ENV=production
PORT=4000

# Base de datos de Products Service
DB_HOST=products-db-host
DB_PORT=5432
DB_USERNAME=products_user
DB_PASSWORD=secure_password_change_me
DB_NAME=products_db_prod

# Base de datos de Orders Service
ORDERS_DB_HOST=orders-db-host
ORDERS_DB_PORT=5432
ORDERS_DB_USERNAME=orders_user
ORDERS_DB_PASSWORD=secure_password_change_me
ORDERS_DB_NAME=orders_db_prod

# URLs de microservicios (para comunicación entre servicios)
PRODUCTS_SERVICE_URL=http://products-service:4001
ORDERS_SERVICE_URL=http://orders-service:4002

# Configuración de JWT (OBLIGATORIO CAMBIAR)
JWT_SECRET=super-secure-jwt-secret-for-production-change-immediately
JWT_EXPIRES_IN=24h

# Configuración de CORS
CORS_ORIGIN=https://your-production-domain.com

# Configuración de logging
LOG_LEVEL=error

# Configuración de Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Configuración de timeouts
HTTP_TIMEOUT=10000

# Configuración de Swagger (desactivar en producción)
SWAGGER_ENABLED=false

# Configuración de SSL
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/app.crt
SSL_KEY_PATH=/etc/ssl/private/app.key

# Configuración de monitoreo
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
